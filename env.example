# ────────── Database ──────────
DATABASE_URL=postgresql://flower:flower@localhost:5432/flower_shop?schema=public

# ────────── Redis (rate-limit, caching) ──────────
REDIS_URL=redis://localhost:6379

# ────────── NextAuth ──────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-me-with-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# Magic-link email (uses Mailhog in dev — open http://localhost:8025)
EMAIL_SERVER=smtp://localhost:1025
EMAIL_FROM=Flower Shop <hello@flower-shop.local>

# Optional OAuth — leave blank to disable
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ────────── Storage (MinIO in dev, S3 / R2 in prod) ──────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=miniominio
S3_BUCKET=flower-shop
S3_PUBLIC_URL=http://localhost:9000/flower-shop

# ────────── App ──────────
APP_URL=http://localhost:3000
SHOP_CURRENCY=USD

# Seeded owner account (created by `npm run db:seed`)
OWNER_EMAIL=owner@flower-shop.local
OWNER_PASSWORD=studio
